# Eureka flash-card bridge — host config
# ───────────────────────────────────────────────────────────────────────────
# Copy to flash-card.env (gitignored) and adjust if your paths differ:
#     cp flash-card.env.example flash-card.env
#
# Who reads this:
#   • setup.sh / start.sh / doctor.sh  — source it as shell env
#   • eureka-bridge.py / listen-watcher.py — auto-load it from this directory
#     (so FlashType's external-ASR call gets the config even though FlashType
#     never sourced your shell). Anything already exported in the shell wins.

# ── Eureka backend endpoints ────────────────────────────────────────────────
# Where the bridge POSTs transcripts and where listen-watcher POSTs mic state.
EUREKA_FLASH_URL=http://localhost:8000/api/flash
EUREKA_LISTENING_URL=http://localhost:8000/api/flash/listening

# ── Whisper.cpp (host-side ASR) ─────────────────────────────────────────────
# whisper-cli comes from `brew install whisper-cpp`; setup.sh downloads the
# model. Swap ggml-base.bin for ggml-small.bin / ggml-medium.bin for higher
# accuracy (slower, larger download).
EUREKA_WHISPER_BIN=/opt/homebrew/bin/whisper-cli
EUREKA_WHISPER_MODEL=$HOME/.flash-type/models/ggml-base.bin
# Language hint for whisper (zh | en | auto | ...). FlashType's {language}
# arg overrides this per-capture when it passes one.
EUREKA_WHISPER_LANG=zh

# ── FlashType (the W1/W2 BLE capture app) ───────────────────────────────────
# listen-watcher tails this log for "Flash memo started/finished" lines to
# drive the「正在聆听」overlay. This is FlashType's default log location.
FLASH_TYPE_LOG=$HOME/.flash-type/flash-type.log
